# このファイルを poc/.env としてコピーし、自分の値に書き換えてください。
# poc/.env は .gitignore 対象なので、絶対にコミットしないでください。

# Tesla Developer Portal で発行したアプリの認証情報
TESLA_CLIENT_ID=your-tesla-client-id
TESLA_CLIENT_SECRET=your-tesla-client-secret

# Tesla Developer Portal の「許可された送信元」に設定した公開ドメイン
# (パートナーアカウント登録・公開鍵ホスティングに使用)
TESLA_DOMAIN=your-username.github.io

# Nature Remo Cloud APIのアクセストークン (https://home.nature.global で発行)
REMO_ACCESS_TOKEN=your-nature-remo-access-token

# Nature Remo E のローカルIPアドレス (同一Wi-Fi内でのテスト用)
REMO_LOCAL_IP=192.168.x.x
